# Optional: Formspree / Web3Forms / custom endpoint for newsletter signup
# Example Formspree: https://formspree.io/f/xxxxxxxx
VITE_NEWSLETTER_ENDPOINT=

# Admin panel — local fallback password (when Supabase is not configured)
VITE_ADMIN_PASSWORD=nuar2025

# Supabase — тот же проект, что и NUAR CRM (https://github.com/wolterGray/nuar-crm)
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
# CRM использует VITE_SUPABASE_PUBLISHABLE_KEY; для сайта подойдёт любое из двух имён:
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Новый CRM backend: используется админкой сайта для SSO и CMS-записи.
VITE_CRM_BACKEND_URL=https://api.nuarr.pl

# Google Analytics 4 (fallback; можно изменить в админке → Аналитика)
VITE_GA_ID=G-NYM3P4FJJE

# Vercel (проект nuarr.pl): Settings → Environment Variables — те же две переменные Supabase
# Локально: скопируйте в .env.local и запускайте npm run dev
